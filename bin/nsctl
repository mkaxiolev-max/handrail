    latest = latest_run_dir()
    latest_ok = latest_ok_run_dir()
    latest_fail = latest_fail_run_dir()
    latest_snapshot = latest_snapshot_dir()

    payload = {
        "command": "dashboard",
        "services": {
            "handrail_http": http_ok("http://127.0.0.1:8011/healthz"),
            "ns_http": http_ok("http://127.0.0.1:9000/healthz"),
            "continuum_http": http_ok("http://127.0.0.1:8788/state"),
        },
        "latest_run_dir": str(latest) if latest else None,
        "latest_ok_run_dir": str(latest_ok) if latest_ok else None,
        "latest_fail_run_dir": str(latest_fail) if latest_fail else None,
        "latest_snapshot_dir": str(latest_snapshot) if latest_snapshot else None,
    }

    if latest:
        payload["latest_summary"] = read_json(latest / "run_summary.json") or {}

    if latest_ok:
        payload["latest_ok_summary"] = read_json(latest_ok / "run_summary.json") or {}

    if latest_fail:
        payload["latest_fail_summary"] = read_json(latest_fail / "run_summary.json") or {}

    print(json.dumps(payload, indent=2))
    sys.exit(0)


def cmd_doctor():
    latest = latest_run_dir()
    latest_ok = latest_ok_run_dir()
    latest_fail = latest_fail_run_dir()
    latest_snapshot = latest_snapshot_dir()

    payload = {
        "command": "doctor",
        "root_exists": ROOT.exists(),
        "runs_root_exists": RUNS_ROOT.exists(),
        "latest_run_dir": str(latest) if latest else None,
        "latest_ok_run_dir": str(latest_ok) if latest_ok else None,
        "latest_fail_run_dir": str(latest_fail) if latest_fail else None,
        "latest_snapshot_dir": str(latest_snapshot) if latest_snapshot else None,
        "services": {
            "handrail_http": http_ok("http://127.0.0.1:8011/healthz"),
            "ns_http": http_ok("http://127.0.0.1:9000/healthz"),
            "continuum_http": http_ok("http://127.0.0.1:8788/state"),
        },
    }

    if latest:
        summary = read_json(latest / "run_summary.json") or {}
        payload["latest_task_type"] = summary.get("task_type")
        payload["resolved_latest_run_dir"] = str(latest)
        payload["resolved_latest_has_summary"] = (latest / "run_summary.json").exists()
        payload["resolved_latest_has_ledger"] = (latest / "proof_ledger.jsonl").exists()

    if latest_fail:
        fail_summary = read_json(latest_fail / "run_summary.json") or {}
        payload["latest_fail_reason"] = fail_summary.get("failure_reason")
        payload["latest_fail_task_type"] = fail_summary.get("task_type")

    print(json.dumps(payload, indent=2))
    sys.exit(0)


def cmd_runs(limit_arg: str | None):
    limit = 12
    if limit_arg:
        try:
            limit = max(1, int(limit_arg))
        except Exception:
            print(json.dumps({"error": "invalid_limit"}, indent=2))
            sys.exit(1)

    print(json.dumps({
        "command": "runs",
        "items": _history_items(limit),
    }, indent=2))
    sys.exit(0)



def cmd_runs_ok(limit: int = 10):
    root = Path("/Volumes/NSExternal/.run/boot")
    items = []
    for d in sorted([p for p in root.iterdir() if p.is_dir()], reverse=True):
        summary = read_json(d / "run_summary.json")
        if not summary:
            continue
        if summary.get("ok") is not True:
            continue
        items.append({
            "kind": "task_run",
            "run_dir": str(d),
            "task_type": summary.get("task_type"),
            "ok": summary.get("ok"),
            "execution_mode": summary.get("execution_mode"),
            "has_summary": True,
            "has_ledger": (d / "proof_ledger.jsonl").exists(),
        })
        if len(items) >= limit:
            break

    print(json.dumps({
        "command": "runs-ok",
        "items": items,
    }, indent=2))
    sys.exit(0)


def cmd_runs_fail(limit: int = 10):
    root = Path("/Volumes/NSExternal/.run/boot")
    items = []
    for d in sorted([p for p in root.iterdir() if p.is_dir()], reverse=True):
        summary = read_json(d / "run_summary.json")
        if not summary:
            continue
        if summary.get("ok") is not False:
            continue
        items.append({
            "kind": "task_run",
            "run_dir": str(d),
            "task_type": summary.get("task_type"),
            "ok": summary.get("ok"),
            "execution_mode": summary.get("execution_mode"),
            "failure_reason": summary.get("failure_reason"),
            "has_summary": True,
            "has_ledger": (d / "proof_ledger.jsonl").exists(),
        })
        if len(items) >= limit:
            break

    print(json.dumps({
        "command": "runs-fail",
        "items": items,
    }, indent=2))
    sys.exit(0)


def _sha256_file(path):
    import hashlib
    path = Path(path)
    if not path.exists() or not path.is_file():
        return None
    return "sha256:" + hashlib.sha256(path.read_bytes()).hexdigest()



def _validate_ledger_chain(ledger_path):
    ledger_path = Path(ledger_path)
    if not ledger_path.exists():
        return False, "missing_ledger"

    try:
        lines = [line for line in ledger_path.read_text().splitlines() if line.strip()]
        prev_hash = None

        for idx, line in enumerate(lines, start=1):
            event = json.loads(line)
            actual_prev = event.get("prev_event_hash")
            if actual_prev != prev_hash:
                return False, f"prev_event_hash_mismatch_at_seq_{idx}"

            event_copy = dict(event)
            event_hash = event_copy.pop("event_hash", None)
            if not event_hash:
                return False, f"missing_event_hash_at_seq_{idx}"

            expected_hash = "sha256:" + __import__("hashlib").sha256(
                json.dumps(event_copy, sort_keys=True).encode("utf-8")
            ).hexdigest()

            if event_hash != expected_hash:
                return False, f"event_hash_mismatch_at_seq_{idx}"

            prev_hash = event_hash

        return True, None
    except Exception as e:
        return False, f"ledger_chain_exception:{e}"

def _validate_run_dir(run_dir):
    run_dir = Path(run_dir)
    summary_path = run_dir / "run_summary.json"
    ledger_path = run_dir / "proof_ledger.jsonl"
    task_request_path = run_dir / "task_request.json"

    if not summary_path.exists():
        return {
            "ok": False,
            "run_dir": str(run_dir),
            "error": "missing_run_summary",
        }

    summary = json.loads(summary_path.read_text())
    errors = []
    missing_artifacts = []

    for item in summary.get("artifact_refs", []):
        artifact_path = Path(item)
        if not artifact_path.exists():
            missing_artifacts.append(str(artifact_path))

    task_request_hash_ok = summary.get("task_request_hash") == _sha256_file(task_request_path)
    ledger_hash_ok = summary.get("ledger_hash") == _sha256_file(ledger_path)
    ledger_chain_ok, ledger_chain_error = _validate_ledger_chain(ledger_path)

    if not ledger_path.exists():
        errors.append("missing_ledger")
    if not task_request_path.exists():
        errors.append("missing_task_request")
    if missing_artifacts:
        errors.append("missing_artifacts")
    if not task_request_hash_ok:
        errors.append("task_request_hash_mismatch")
    if not ledger_hash_ok:
        errors.append("ledger_hash_mismatch")
    if not ledger_chain_ok:
        errors.append(ledger_chain_error or "ledger_chain_invalid")

    mutation_required = []
    if summary.get("task_type") == "ops_apply_patch":
        mutation_required = [
            "state_before.json",
            "simulated_transition.json",
            "state_after.json",
            "actual_delta.json",
            "patch.diff",
        ]
        for name in mutation_required:
            if not (run_dir / name).exists():
                errors.append(f"missing_mutation_artifact:{name}")

    children_root = run_dir / "children"
    child_dirs = sorted([x for x in children_root.iterdir() if x.is_dir()]) if children_root.exists() else []
    child_results = [_validate_run_dir(child) for child in child_dirs]
    children_ok = all(x.get("ok", False) for x in child_results)

    if not children_ok:
        errors.append("child_validation_failed")

    return {
        "ok": len(errors) == 0,
        "run_dir": str(run_dir),
        "task_type": summary.get("task_type"),
        "artifacts_ok": len(missing_artifacts) == 0,
        "missing_artifacts": missing_artifacts,
        "task_request_hash_ok": task_request_hash_ok,
        "ledger_hash_ok": ledger_hash_ok,
        "ledger_chain_ok": ledger_chain_ok,
        "ledger_chain_error": ledger_chain_error,
        "mutation_artifacts_required": mutation_required,
        "children_checked": len(child_results),
        "children_ok": children_ok,
        "children": child_results,
        "errors": errors,
    }


def cmd_validate_run(target):
    result = _validate_run_dir(target)
    print(json.dumps(result, indent=2))
    return 0 if result.get("ok") else 1



def cmd_replay_run(target):
    from services.handrail.handrail.replay_engine import replay_run
    import json

    result = replay_run(target, dry_run=True)
    print(json.dumps(result, indent=2))
    return 0


def cmd_opcode(op):
    from services.handrail.handrail.opcode import parse_opcode

    parsed = parse_opcode(op)

    code, out, err = _post_task(
        parsed["task_type"],
        parsed["objective"],
        parsed.get("payload", {})
    )

    if out.strip():
        print(out.strip())

    if err.strip():
        print(err.strip())

    return code


def cmd_env_action(adapter_method: str, params_json: str | None = None, objective: str | None = None):
    try:
        payload_params = json.loads(params_json) if params_json else {}
    except Exception:
        print(json.dumps({"error": "invalid_params_json"}, indent=2))
        sys.exit(1)

    now = int(__import__("time").time() * 1000)
    body = {
        "task_type": "ops_env_action",
        "objective": objective or f"run adapter method {adapter_method}",
        "payload": {
            "adapter_method": adapter_method,
            "adapter_params": payload_params,
            "run_id": f"env_{now}",
            "action_id": f"act_{now}",
        },
    }

    cmd = (
        "curl -sS -X POST http://127.0.0.1:8011/v1/task "
        "-H 'Content-Type: application/json' "
        f"-d '{json.dumps(body)}'"
    )
    code, out, err = run_cmd(cmd)
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    sys.exit(code)

def main():
    if len(sys.argv) < 2:
        print("Usage: nsctl <boot|status|opcode|env-action|latest|latest-ok|latest-fail|validate-run|replay|run|exec|ns-exec|stdout|cat|open|snapshot|reset|doctor|dashboard|summary|ok-ledger|fail-ledger|tail-fail|runs|runs-ok|runs-fail> [arg]")
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "boot":
        cmd_boot()
    elif cmd == "status":
        cmd_status()
    elif cmd == "opcode":
        cmd_opcode(sys.argv[2])
    elif cmd == "env-action" and len(sys.argv) > 2:
        params_json = sys.argv[3] if len(sys.argv) > 3 else "{}"
        objective = sys.argv[4] if len(sys.argv) > 4 else None
        cmd_env_action(sys.argv[2], params_json, objective)
    elif cmd == "latest":
        cmd_latest()
    elif cmd == "latest-ok":
        cmd_latest_ok()
    elif cmd == "latest-fail":
        cmd_latest_fail()
    elif cmd == "validate-run" and len(sys.argv) > 2:
        sys.exit(cmd_validate_run(sys.argv[2]))
    elif cmd == "replay" and len(sys.argv) > 2:
        sys.exit(cmd_replay_run(sys.argv[2]))

    elif cmd == "run" and len(sys.argv) > 2:
        cmd_run(sys.argv[2])
    elif cmd == "exec" and len(sys.argv) > 2:
        cmd_exec(" ".join(sys.argv[2:]))
    elif cmd == "ns-exec" and len(sys.argv) > 2:
        import subprocess
        import requests

        raw_cmd = " ".join(sys.argv[2:])

        key = subprocess.check_output(
            ["docker", "compose", "exec", "-T", "ns", "sh", "-lc", "printf '%s' \"$NS_OPS_KEY\""]
        ).decode().strip()

        r = requests.post(
            "http://127.0.0.1:9000/ingest/exec",
            headers={
                "Content-Type": "application/json",
                "X-NS-OPS-KEY": key,
            },
            json={"cmd": raw_cmd},
            timeout=30,
        )

        print(json.dumps(r.json(), indent=2))
        sys.exit(0)
    elif cmd == "stdout" and len(sys.argv) > 2:
        cmd_stdout(sys.argv[2])
    elif cmd == "cat" and len(sys.argv) > 3:
        cmd_cat(sys.argv[2], sys.argv[3])
    elif cmd == "open" and len(sys.argv) > 2:
        cmd_open(sys.argv[2])
    elif cmd == "snapshot":
        cmd_snapshot()
    elif cmd == "reset":
        cmd_reset()
    elif cmd == "doctor":
        cmd_doctor()
    elif cmd == "dashboard":
        cmd_dashboard()
    elif cmd == "summary":
        cmd_summary()
    elif cmd == "ok-ledger":
        cmd_ok_ledger()
    elif cmd == "fail-ledger":
        cmd_fail_ledger()
    elif cmd == "tail-fail":
        cmd_tail_fail()
    elif cmd == "runs":
        arg = sys.argv[2] if len(sys.argv) > 2 else None
        cmd_runs(arg)
    elif cmd == "runs-ok":
        limit = int(sys.argv[2]) if len(sys.argv) > 2 else 10
        cmd_runs_ok(limit)
    elif cmd == "runs-fail":
        limit = int(sys.argv[2]) if len(sys.argv) > 2 else 10
        cmd_runs_fail(limit)

    else:
        print("Usage: nsctl <boot|status|opcode|env-action|latest|latest-ok|latest-fail|validate-run|replay|run|exec|ns-exec|stdout|cat|open|snapshot|reset|doctor|dashboard|summary|ok-ledger|fail-ledger|tail-fail|runs|runs-ok|runs-fail> [arg]")
        sys.exit(1)


if __name__ == "__main__":
    main()
