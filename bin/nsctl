#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

ROOT = Path.home() / "axiolev_runtime"
RUNS_ROOT = Path("/Volumes/NSExternal/.run/boot")


def run_cmd(cmd: str, cwd: Path | None = None) -> tuple[int, str, str]:
    p = subprocess.run(
        cmd,
        shell=True,
        cwd=str(cwd or ROOT),
        text=True,
        capture_output=True,
    )
    return p.returncode, p.stdout, p.stderr


def read_json(path: Path):
    if not path.exists():
        return None
    try:
        return json.loads(path.read_text())
    except Exception:
        return None


def latest_run_dir() -> Path | None:
    if not RUNS_ROOT.exists():
        return None
    runs = [p for p in RUNS_ROOT.iterdir() if p.is_dir() and p.name[:2] == "20"]
    if not runs:
        return None
    return sorted(runs, key=lambda p: p.stat().st_mtime, reverse=True)[0]


def resolve_governed_run(task_run: Path) -> Path:
    result = read_json(task_run / "result.json") or {}
    governed = result.get("boot_go_run_dir")
    if governed:
        return Path(governed)
    return task_run


def summarize_run(run_dir: Path) -> dict:
    summary = read_json(run_dir / "run_summary.json")
    if summary:
        return {
            "latest_run_dir": str(run_dir),
            "run_summary": summary,
        }

    files = sorted([p.name for p in run_dir.iterdir() if p.is_file()]) if run_dir.exists() else []
    return {
        "latest_run_dir": str(run_dir),
        "files": files,
    }


def _post_task(task_type: str, objective: str) -> tuple[int, str, str]:
    payload = {
        "task_type": task_type,
        "objective": objective,
        "payload": {},
    }
    cmd = (
        "curl -sS -X POST http://127.0.0.1:8011/v1/task "
        "-H 'Content-Type: application/json' "
        f"-d '{json.dumps(payload)}'"
    )
    return run_cmd(cmd)


def _print_latest_resolved() -> int:
    latest = latest_run_dir()
    if not latest:
        print(json.dumps({"error": "no_runs_found"}, indent=2))
        return 1

    result = read_json(latest / "result.json") or {}
    task_type = result.get("task_type")

    if task_type == "ops_boot_check":
        chosen = resolve_governed_run(latest)
        print(json.dumps(summarize_run(chosen), indent=2))
        return 0

    print(json.dumps(summarize_run(latest), indent=2))
    return 0


def cmd_boot():
    code, out, err = _post_task("ops_boot_check", "run governed boot through nsctl")
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    if code != 0:
        sys.exit(code)
    print()
    sys.exit(_print_latest_resolved())


def cmd_status():
    code, out, err = _post_task("ops_status_check", "inspect current runtime health through nsctl")
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    if code != 0:
        sys.exit(code)
    print()
    sys.exit(_print_latest_resolved())


def cmd_latest():
    sys.exit(_print_latest_resolved())


def cmd_run(task_type: str):
    code, out, err = _post_task(task_type, f"run governed task {task_type} through nsctl")
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    if code != 0:
        sys.exit(code)
    print()
    sys.exit(_print_latest_resolved())


def cmd_open(target: str):
    if target == "latest":
        latest = latest_run_dir()
        if not latest:
            print("No runs found")
            sys.exit(1)
        result = read_json(latest / "result.json") or {}
        if result.get("task_type") == "ops_boot_check":
            chosen = resolve_governed_run(latest)
        else:
            chosen = latest
    else:
        matches = sorted(RUNS_ROOT.glob(f"{target}*"))
        if not matches:
            print(f"No run found for: {target}")
            sys.exit(1)
        chosen = matches[0]

    print(str(chosen))
    subprocess.run(["open", str(chosen)], check=False)


def main():
    if len(sys.argv) < 2:
        print("Usage: nsctl <boot|status|latest|run|open> [arg]")
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "boot":
        cmd_boot()
    elif cmd == "status":
        cmd_status()
    elif cmd == "latest":
        cmd_latest()
    elif cmd == "run" and len(sys.argv) > 2:
        cmd_run(sys.argv[2])
    elif cmd == "open" and len(sys.argv) > 2:
        cmd_open(sys.argv[2])
    else:
        print("Usage: nsctl <boot|status|latest|run|open> [arg]")
        sys.exit(1)


if __name__ == "__main__":
    main()
