#!/usr/bin/env python3
from pathlib import Path
import json,sys
sys.path.insert(0,str(Path(__file__).parent.parent))
from services.handrail.handrail.plans.schema import PlanSpec
from services.handrail.handrail.plans.runner import PlanRunner
def main()->int:
 if len(sys.argv)<3 or sys.argv[1]!="run-plan":print("usage: nsctl run-plan <plan.json>");return 2
 plan_path=Path(sys.argv[2])
 raw=json.loads(plan_path.read_text())
 plan=PlanSpec.from_dict(raw)
 result=PlanRunner().run(plan)
 print(json.dumps(result,indent=2))
 return 0 if result.get("ok")else 1
if __name__=="__main__":raise SystemExit(main())
