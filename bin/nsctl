#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

ROOT = Path.home() / "axiolev_runtime"
RUNS_ROOT = Path("/Volumes/NSExternal/.run/boot")


def run_local(cmd: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd,
        cwd=str(ROOT),
        text=True,
        capture_output=True,
    )


def latest_run_dir() -> Path | None:
    if not RUNS_ROOT.exists():
        return None
    runs = [p for p in RUNS_ROOT.iterdir() if p.is_dir() and p.name[:2] == "20"]
    if not runs:
        return None
    return sorted(runs, key=lambda p: p.stat().st_mtime, reverse=True)[0]


def read_json(path: Path):
    if not path.exists():
        return None
    try:
        return json.loads(path.read_text())
    except Exception:
        return None


def curl_json(url: str, method: str = "GET", data: dict | None = None):
    cmd = ["curl", "-sS"]
    if method != "GET":
        cmd += ["-X", method]
    if data is not None:
        cmd += ["-H", "Content-Type: application/json", "-d", json.dumps(data)]
    cmd.append(url)
    p = run_local(cmd)
    if p.returncode != 0:
        print(p.stderr.strip() or p.stdout.strip(), file=sys.stderr)
        sys.exit(p.returncode)
    try:
        return json.loads(p.stdout)
    except Exception:
        print(p.stdout)
        sys.exit(1)


def print_json(data):
    print(json.dumps(data, indent=2))


def cmd_boot():
    data = curl_json(
        "http://127.0.0.1:8011/v1/task",
        method="POST",
        data={
            "task_type": "ops_boot_check",
            "objective": "run governed boot through nsctl",
        },
    )
    print_json(data)


def cmd_status():
    data = curl_json(
        "http://127.0.0.1:8011/v1/task",
        method="POST",
        data={
            "task_type": "ops_status_check",
            "objective": "inspect runtime health through nsctl",
        },
    )
    print_json(data)


def cmd_latest():
    run_dir = latest_run_dir()
    if not run_dir:
        print("No runs found", file=sys.stderr)
        sys.exit(1)

    result = read_json(run_dir / "result.json")
    if result and result.get("boot_go_run_dir"):
        governed_dir = Path(result["boot_go_run_dir"])
        governed_summary = read_json(governed_dir / "run_summary.json")
        payload = {
            "latest_task_run_dir": str(run_dir),
            "governed_run_dir": str(governed_dir),
            "governed_run_summary": governed_summary,
        }
        print_json(payload)
        return

    direct_summary = read_json(run_dir / "run_summary.json")
    if direct_summary:
        payload = {
            "latest_run_dir": str(run_dir),
            "run_summary": direct_summary,
        }
        print_json(payload)
        return

    payload = {
        "latest_run_dir": str(run_dir),
        "files": sorted([p.name for p in run_dir.iterdir()]),
    }
    print_json(payload)


def cmd_run(task_type: str):
    data = curl_json(
        "http://127.0.0.1:8011/v1/task",
        method="POST",
        data={
            "task_type": task_type,
            "objective": f"run governed task {task_type} through nsctl",
        },
    )
    print_json(data)


def cmd_open(run_id: str):
    matches = sorted(
        [p for p in RUNS_ROOT.iterdir() if p.is_dir() and run_id in p.name],
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    if not matches:
        print(f"No run found for: {run_id}", file=sys.stderr)
        sys.exit(1)

    target = matches[0]
    print(str(target))
    subprocess.run(["open", str(target)], check=False)


def usage():
    print("Usage: nsctl <boot|status|latest|run|open> [arg]", file=sys.stderr)
    sys.exit(1)


def main():
    if len(sys.argv) < 2:
        usage()

    cmd = sys.argv[1]

    if cmd == "boot":
        cmd_boot()
        return
    if cmd == "status":
        cmd_status()
        return
    if cmd == "latest":
        cmd_latest()
        return
    if cmd == "run" and len(sys.argv) >= 3:
        cmd_run(sys.argv[2])
        return
    if cmd == "open" and len(sys.argv) >= 3:
        cmd_open(sys.argv[2])
        return

    usage()


if __name__ == "__main__":
    main()
