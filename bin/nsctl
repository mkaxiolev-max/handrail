#!/usr/bin/env python3
import json
import subprocess
import sys
from pathlib import Path

ROOT = Path.home() / "axiolev_runtime"
RUNS_ROOT = Path("/Volumes/NSExternal/.run/boot")


def run_cmd(cmd: str):
    p = subprocess.run(
        cmd,
        shell=True,
        cwd=str(ROOT),
        text=True,
        capture_output=True,
    )
    return p.returncode, p.stdout, p.stderr


def read_json(path: Path):
    try:
        return json.loads(path.read_text())
    except Exception:
        return None


def all_run_dirs():
    if not RUNS_ROOT.exists():
        return []
    return sorted(
        [p for p in RUNS_ROOT.iterdir() if p.is_dir()],
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )


def is_task_run_dir(run_dir: Path) -> bool:
    return (run_dir / "task_request.json").exists() or (run_dir / "result.json").exists()


def is_governed_run_dir(run_dir: Path) -> bool:
    return (run_dir / "run_summary.json").exists() and (run_dir / "proof_ledger.jsonl").exists()


def is_snapshot_dir(run_dir: Path) -> bool:
    snapshot_markers = {
        "compose_config.txt",
        "compose_ps.txt",
        "continuum_state.json",
        "handrail_healthz.json",
        "logs_tail.txt",
        "meta.txt",
        "ns_healthz.json",
    }
    names = {p.name for p in run_dir.iterdir() if p.is_file()} if run_dir.exists() else set()
    return len(snapshot_markers.intersection(names)) >= 3 and not is_task_run_dir(run_dir) and not is_governed_run_dir(run_dir)


def latest_run_dir():
    for run_dir in all_run_dirs():
        if is_task_run_dir(run_dir) or is_governed_run_dir(run_dir):
            return run_dir
    runs = all_run_dirs()
    return runs[0] if runs else None


def latest_snapshot_dir():
    for run_dir in all_run_dirs():
        if is_snapshot_dir(run_dir):
            return run_dir
    return None


def resolve_governed_run(task_run: Path):
    result = read_json(task_run / "result.json") or {}
    boot_go_run_dir = result.get("boot_go_run_dir")
    if boot_go_run_dir:
        p = Path(boot_go_run_dir)
        if p.exists():
            return p
    return task_run


def summarize_run(run_dir: Path):
    summary = read_json(run_dir / "run_summary.json")
    if summary:
        return {
            "latest_run_dir": str(run_dir),
            "run_summary": summary,
        }

    files = sorted([p.name for p in run_dir.iterdir() if p.is_file()]) if run_dir.exists() else []
    return {
        "latest_run_dir": str(run_dir),
        "files": files,
    }


def _post_task(task_type: str, objective: str):
    payload = {
        "task_type": task_type,
        "objective": objective,
        "payload": {},
    }
    cmd = (
        "curl -sS -X POST http://127.0.0.1:8011/v1/task "
        "-H 'Content-Type: application/json' "
        f"-d '{json.dumps(payload)}'"
    )
    return run_cmd(cmd)


def _print_latest_resolved():
    latest = latest_run_dir()
    if not latest:
        print(json.dumps({"error": "no_runs_found"}, indent=2))
        return 1

    result = read_json(latest / "result.json") or {}
    task_type = result.get("task_type")

    if task_type == "ops_boot_check":
        chosen = resolve_governed_run(latest)
        print(json.dumps(summarize_run(chosen), indent=2))
        return 0

    print(json.dumps(summarize_run(latest), indent=2))
    return 0


def _history_items(limit: int):
    items = []
    for run_dir in all_run_dirs():
        if is_snapshot_dir(run_dir):
            continue

        result = read_json(run_dir / "result.json") or {}
        summary = read_json(run_dir / "run_summary.json") or {}

        if result.get("task_type") == "ops_boot_check":
            governed = resolve_governed_run(run_dir)
            governed_summary = read_json(governed / "run_summary.json") or {}
            items.append({
                "kind": "boot_task",
                "task_run_dir": str(run_dir),
                "governed_run_dir": str(governed),
                "task_type": governed_summary.get("task_type") or result.get("task_type"),
                "ok": governed_summary.get("ok"),
                "execution_mode": governed_summary.get("execution_mode"),
                "has_summary": (governed / "run_summary.json").exists(),
                "has_ledger": (governed / "proof_ledger.jsonl").exists(),
            })
        elif summary:
            items.append({
                "kind": "task_run",
                "run_dir": str(run_dir),
                "task_type": summary.get("task_type"),
                "ok": summary.get("ok"),
                "execution_mode": summary.get("execution_mode"),
                "has_summary": (run_dir / "run_summary.json").exists(),
                "has_ledger": (run_dir / "proof_ledger.jsonl").exists(),
            })
        elif result:
            items.append({
                "kind": "task_run",
                "run_dir": str(run_dir),
                "task_type": result.get("task_type"),
                "ok": result.get("ok"),
                "execution_mode": None,
                "has_summary": (run_dir / "run_summary.json").exists(),
                "has_ledger": (run_dir / "proof_ledger.jsonl").exists(),
            })

        if len(items) >= limit:
            break
    return items


def cmd_boot():
    code, out, err = _post_task("ops_boot_check", "run governed boot through nsctl")
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    if code != 0:
        sys.exit(code)
    print()
    sys.exit(_print_latest_resolved())


def cmd_status():
    code, out, err = _post_task("ops_status_check", "inspect current runtime health through nsctl")
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    if code != 0:
        sys.exit(code)
    print()
    sys.exit(_print_latest_resolved())


def cmd_latest():
    sys.exit(_print_latest_resolved())


def cmd_run(task_type: str):
    code, out, err = _post_task(task_type, f"run governed task {task_type} through nsctl")
    if out.strip():
        print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    if code != 0:
        sys.exit(code)
    print()
    sys.exit(_print_latest_resolved())


def cmd_open(target: str):
    if target == "latest":
        latest = latest_run_dir()
        if not latest:
            print("No runs found")
            sys.exit(1)
        result = read_json(latest / "result.json") or {}
        if result.get("task_type") == "ops_boot_check":
            chosen = resolve_governed_run(latest)
        else:
            chosen = latest
    elif target == "snapshot":
        chosen = latest_snapshot_dir()
        if not chosen:
            print("No snapshot found")
            sys.exit(1)
    else:
        matches = sorted(RUNS_ROOT.glob(f"{target}*"))
        if not matches:
            print(f"No run found for: {target}")
            sys.exit(1)
        chosen = matches[0]

    print(str(chosen))
    subprocess.run(["open", str(chosen)], check=False)


def cmd_snapshot():
    code, out, err = run_cmd("./scripts/boot/snapshot.sh")
    payload = {
        "command": "snapshot",
        "ok": code == 0,
        "stdout": out.strip(),
        "stderr": err.strip(),
    }
    print(json.dumps(payload, indent=2))
    sys.exit(code)


def cmd_reset():
    code, out, err = run_cmd("./scripts/boot/reset_clean.sh")
    payload = {
        "command": "reset",
        "ok": code == 0,
        "stdout": out.strip(),
        "stderr": err.strip(),
    }
    print(json.dumps(payload, indent=2))
    sys.exit(code)


def cmd_doctor():
    payload = {
        "command": "doctor",
        "root_exists": ROOT.exists(),
        "runs_root_exists": RUNS_ROOT.exists(),
        "latest_run_dir": str(latest_run_dir()) if latest_run_dir() else None,
        "latest_snapshot_dir": str(latest_snapshot_dir()) if latest_snapshot_dir() else None,
    }

    health_code, _, _ = run_cmd("curl -sS http://127.0.0.1:8011/healthz >/dev/null")
    ns_code, _, _ = run_cmd("curl -sS http://127.0.0.1:9000/healthz >/dev/null")
    continuum_code, _, _ = run_cmd("curl -sS http://127.0.0.1:8788/state >/dev/null")

    payload["services"] = {
        "handrail_http": health_code == 0,
        "ns_http": ns_code == 0,
        "continuum_http": continuum_code == 0,
    }

    latest = latest_run_dir()
    if latest:
        result = read_json(latest / "result.json") or {}
        payload["latest_task_type"] = result.get("task_type")
        if result.get("task_type") == "ops_boot_check":
            governed = resolve_governed_run(latest)
            payload["resolved_latest_run_dir"] = str(governed)
            payload["resolved_latest_has_summary"] = (governed / "run_summary.json").exists()
            payload["resolved_latest_has_ledger"] = (governed / "proof_ledger.jsonl").exists()
        else:
            payload["resolved_latest_run_dir"] = str(latest)
            payload["resolved_latest_has_summary"] = (latest / "run_summary.json").exists()
            payload["resolved_latest_has_ledger"] = (latest / "proof_ledger.jsonl").exists()

    print(json.dumps(payload, indent=2))
    sys.exit(0 if all(payload["services"].values()) else 1)


def cmd_runs(limit_arg: str | None):
    limit = 12
    if limit_arg:
        try:
            limit = max(1, int(limit_arg))
        except Exception:
            print(json.dumps({"error": "invalid_limit"}, indent=2))
            sys.exit(1)

    print(json.dumps({
        "command": "runs",
        "items": _history_items(limit),
    }, indent=2))
    sys.exit(0)


def main():
    if len(sys.argv) < 2:
        print("Usage: nsctl <boot|status|latest|run|open|snapshot|reset|doctor|runs> [arg]")
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "boot":
        cmd_boot()
    elif cmd == "status":
        cmd_status()
    elif cmd == "latest":
        cmd_latest()
    elif cmd == "run" and len(sys.argv) > 2:
        cmd_run(sys.argv[2])
    elif cmd == "open" and len(sys.argv) > 2:
        cmd_open(sys.argv[2])
    elif cmd == "snapshot":
        cmd_snapshot()
    elif cmd == "reset":
        cmd_reset()
    elif cmd == "doctor":
        cmd_doctor()
    elif cmd == "runs":
        arg = sys.argv[2] if len(sys.argv) > 2 else None
        cmd_runs(arg)
    else:
        print("Usage: nsctl <boot|status|latest|run|open|snapshot|reset|doctor|runs> [arg]")
        sys.exit(1)


if __name__ == "__main__":
    main()
