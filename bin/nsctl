#!/usr/bin/env python3
import json
import subprocess
import sys
from pathlib import Path

ROOT = Path.home() / "axiolev_runtime"
RUNS_ROOT = Path("/Volumes/NSExternal/.run/boot")


def run_cmd(cmd: str):
    p = subprocess.run(
        cmd,
        shell=True,
        cwd=str(ROOT),
        text=True,
        capture_output=True,
    )
    return p.returncode, p.stdout, p.stderr


def latest_run_dir():
    if not RUNS_ROOT.exists():
        return None
    runs = sorted(
        [p for p in RUNS_ROOT.iterdir() if p.is_dir() and p.name[:2] == "20"],
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    return runs[0] if runs else None


def read_json(path: Path):
    try:
        return json.loads(path.read_text())
    except Exception:
        return None


def resolve_governed_run(run_dir: Path) -> Path:
    result_json = run_dir / "result.json"
    if result_json.exists():
        data = read_json(result_json) or {}
        boot_go_run_dir = data.get("boot_go_run_dir")
        if boot_go_run_dir:
            p = Path(boot_go_run_dir)
            if p.exists():
                return p
    return run_dir


def summarize_run(run_dir: Path):
    summary_json = run_dir / "run_summary.json"
    if summary_json.exists():
        return {
            "latest_run_dir": str(run_dir),
            "run_summary": read_json(summary_json),
        }

    result_json = run_dir / "result.json"
    if result_json.exists():
        result = read_json(result_json) or {}
        governed = result.get("boot_go_run_dir")
        if governed:
            governed_path = Path(governed)
            governed_summary = read_json(governed_path / "run_summary.json")
            if governed_summary:
                return {
                    "latest_task_run_dir": str(run_dir),
                    "governed_run_dir": str(governed_path),
                    "governed_run_summary": governed_summary,
                }

    files = sorted([p.name for p in run_dir.iterdir() if p.is_file()]) if run_dir.exists() else []
    return {
        "latest_run_dir": str(run_dir),
        "files": files,
    }


def cmd_boot():
    payload = {
        "task_type": "ops_boot_check",
        "objective": "run governed boot through nsctl",
        "payload": {},
    }
    cmd = (
        "curl -sS -X POST http://127.0.0.1:8011/v1/task "
        "-H 'Content-Type: application/json' "
        f"-d '{json.dumps(payload)}'"
    )
    code, out, err = run_cmd(cmd)
    print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    sys.exit(code)


def cmd_status():
    payload = {
        "task_type": "ops_status_check",
        "objective": "inspect current runtime health through nsctl",
        "payload": {},
    }
    cmd = (
        "curl -sS -X POST http://127.0.0.1:8011/v1/task "
        "-H 'Content-Type: application/json' "
        f"-d '{json.dumps(payload)}'"
    )
    code, out, err = run_cmd(cmd)
    print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    sys.exit(code)


def cmd_latest():
    latest = latest_run_dir()
    if not latest:
        print(json.dumps({"error": "no_runs_found"}, indent=2))
        sys.exit(1)

    result = read_json(latest / "result.json") or {}
    task_type = result.get("task_type")

    if task_type == "ops_boot_check":
        chosen = resolve_governed_run(latest)
        print(json.dumps(summarize_run(chosen), indent=2))
        return

    print(json.dumps(summarize_run(latest), indent=2))


def cmd_run(task_type):
    payload = {
        "task_type": task_type,
        "objective": f"run governed task {task_type} through nsctl",
        "payload": {},
    }
    cmd = (
        "curl -sS -X POST http://127.0.0.1:8011/v1/task "
        "-H 'Content-Type: application/json' "
        f"-d '{json.dumps(payload)}'"
    )
    code, out, err = run_cmd(cmd)
    print(out.strip())
    if err.strip():
        print(err.strip(), file=sys.stderr)
    sys.exit(code)


def cmd_open(target):
    if target == "latest":
        latest = latest_run_dir()
        if not latest:
            print("No runs found")
            sys.exit(1)
        result = read_json(latest / "result.json") or {}
        if result.get("task_type") == "ops_boot_check":
            chosen = resolve_governed_run(latest)
        else:
            chosen = latest
    else:
        matches = sorted(RUNS_ROOT.glob(f"{target}*"))
        if not matches:
            print(f"No run found for: {target}")
            sys.exit(1)
        chosen = matches[0]

    print(str(chosen))
    subprocess.run(["open", str(chosen)], check=False)


def main():
    if len(sys.argv) < 2:
        print("Usage: nsctl <boot|status|latest|run|open> [arg]")
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "boot":
        cmd_boot()
    elif cmd == "status":
        cmd_status()
    elif cmd == "latest":
        cmd_latest()
    elif cmd == "run" and len(sys.argv) > 2:
        cmd_run(sys.argv[2])
    elif cmd == "open" and len(sys.argv) > 2:
        cmd_open(sys.argv[2])
    else:
        print("Usage: nsctl <boot|status|latest|run|open> [arg]")
        sys.exit(1)


if __name__ == "__main__":
    main()
