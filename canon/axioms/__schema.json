{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AxiomEntry",
  "type": "object",
  "required": ["id", "name", "class"],
  "properties": {
    "id":    {"type": "string", "pattern": "^AX-[0-9]+$"},
    "name":  {"type": "string"},
    "class": {"type": "string", "enum": ["structural", "epistemic", "procedural", "never_event", "governance"]}
  },
  "additionalProperties": false
}
