{"bundle_id":"stewart_negotiation_policy_v1","version":"1.0.0","role":"stewart_negotiation_operator",
 "allowed_states":["S4_STRUCTURE","S5_VALIDATION","S6_NEGOTIATION","S7_CLOSE","S8_COMMIT"],
 "memory_scope_spec":{"include":["pricing_history","objections","decision_map","prior_commitments","deal_structure"],"exclude":["founder_personal_notes","heidi_clinical_context","advisor_terms"]},
