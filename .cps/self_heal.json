{
  "cps_id": "self_heal",
  "objective": "5-op self-monitoring — health check all services + SSD + Merkle proof + alert on degradation",
  "policy_profile": "readonly.local",
  "ops": [
    {
      "op": "http.health_check",
      "args": { "url": "http://localhost:9000/healthz", "expect_status": 200 }
    },
    {
      "op": "http.health_check",
      "args": { "url": "http://localhost:8788/state", "expect_status": 200 }
    },
    {
      "op": "sys.disk_usage",
      "args": { "path": "/Volumes/NSExternal" }
    },
    {
      "op": "http.get",
      "args": { "url": "http://localhost:9000/alexandria/proof" }
    },
    {
      "op": "http.get",
      "args": { "url": "http://localhost:9000/health/full" }
    }
  ],
  "expect": {
    "results[0].data.healthy": true,
    "results[1].data.healthy": true,
    "results[3].data.body.proof_valid": true
  }
}
