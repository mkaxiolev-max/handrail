{
  "cps_id": "boot_and_prove",
  "objective": "Canonical boot proof sequence — sovereignty verification post-boot",
  "policy_profile": "readonly.local",
  "ops": [
    {
      "op": "fs.pwd",
      "args": {}
    },
    {
      "op": "http.health_check",
      "args": { "url": "http://ns:9000/healthz", "expect_status": 200 }
    },
    {
      "op": "http.health_check",
      "args": { "url": "http://continuum:8788/state", "expect_status": 200 }
    },
    {
      "op": "http.get",
      "args": { "url": "http://ns:9000/alexandria/proof" }
    },
    {
      "op": "http.get",
      "args": { "url": "http://ns:9000/auth/yubikey/test" }
    },
    {
      "op": "sys.disk_usage",
      "args": { "path": "/Volumes/NSExternal" }
    },
    {
      "op": "slack.notify",
      "args": { "text": "NS∞ boot complete and proven — sovereignty verified, all checks passed" }
    }
  ],
  "expect": {
    "results[1].data.healthy": true,
    "results[2].data.healthy": true,
    "results[3].data.body.proof_valid": true,
    "results[4].data.body.client_id_set": true
  }
}
