from pathlib import Path
import subprocess
import json

ALLOWED_ROOT = Path("/app")

def run_tests(task_request, run_dir):

    test_command = task_request.get("test_command", "pytest -q")

    try:

        result = subprocess.run(
            test_command,
            cwd=ALLOWED_ROOT,
            shell=True,
            capture_output=True,
            text=True
        )

        stdout = result.stdout
        stderr = result.stderr

        (Path(run_dir) / "tests_stdout.txt").write_text(stdout)
        (Path(run_dir) / "tests_stderr.txt").write_text(stderr)

        return {
            "ok": result.returncode == 0,
            "rc": result.returncode,
            "stdout": stdout,
            "stderr": stderr,
        }

    except Exception as e:

        return {
            "ok": False,
            "failure_reason": str(e)
        }
