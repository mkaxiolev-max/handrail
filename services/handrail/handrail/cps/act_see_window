{
  "cps_id": "act_see_window",
  "objective": "ACT: focus Terminal window. SEE: verify focused window changed. Closes the ACT+SEE loop.",
  "policy_profile": "readonly.local",
  "ops": [
    {
      "op": "http.post",
      "args": {
        "url": "http://host.docker.internal:9911/adapter/v1/run",
        "json": { "method": "window.list", "params": {} },
        "timeout_ms": 5000
      }
    },
    {
      "op": "http.post",
      "args": {
        "url": "http://host.docker.internal:9911/adapter/v1/run",
        "json": { "method": "window.focus", "params": { "app": "Terminal" } },
        "timeout_ms": 5000
      }
    },
    {
      "op": "http.post",
      "args": {
        "url": "http://host.docker.internal:9911/adapter/v1/run",
        "json": { "method": "window.get_focused", "params": {} },
        "timeout_ms": 5000
      }
    }
  ],
  "expect": {
    "results[0].data.status_code": 200,
    "results[1].data.status_code": 200,
    "results[2].data.status_code": 200
  }
}
