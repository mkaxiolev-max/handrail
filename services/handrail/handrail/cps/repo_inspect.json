{
  "cps_id": "repo_inspect",
  "objective": "inspect runtime repo state",
  "policy_profile": "repo.inspect",
  "ops": [
    {
      "op": "git.status",
      "args": {
        "repo": "/workspace"
      }
    },
    {
      "op": "git.log",
      "args": {
        "repo": "/workspace",
        "limit": 5,
        "oneline": true
      }
    }
  ],
  "expect": {}
}
