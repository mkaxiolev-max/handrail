# NORTHSTAR Environment Configuration (v2.1)
# Copy to ~/NSS/.env and fill in values.
# NEVER commit secrets.

# ── Core ─────────────────────────────────────────────────────
NS_FOUNDER_PASSWORD=change-me
NORTHSTAR_PORT=9000

# ── Storage paths (optional overrides) ────────────────────────
# Default behavior:
#   - If /Volumes/NSExternal exists: /Volumes/NSExternal/ALEXANDRIA
#   - Else: ~/ALEXANDRIA
#   - Manifold defaults: ~/NSS/MANIFOLD
NORTHSTAR_SSD_MOUNT=/Volumes/NSExternal
NORTHSTAR_ALEXANDRIA_ROOT=
NORTHSTAR_MANIFOLD_ROOT=
NORTHSTAR_CONFIG_ROOT=
NORTHSTAR_LOG_ROOT=

# ── LLM Keys (optional but recommended) ───────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=

# ── Twilio (required for inbound voice + SMS) ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: caller tier mapping
FOUNDER_PHONE=

# Webhook base (ngrok tunnel HTTPS for Twilio callbacks)
# This is automatically written by NORTHSTAR.command when ngrok is running.
NORTHSTAR_WEBHOOK_BASE=

# Optional hardening
TWILIO_VALIDATE_SIGNATURE=0

# ── Trading / Data (optional) ─────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
POLYGON_API_KEY=
FRED_API_KEY=
NEWSAPI_KEY=
