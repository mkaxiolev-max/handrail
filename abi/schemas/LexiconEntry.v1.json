{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axiolev/abi/LexiconEntry.v1",
  "title": "LexiconEntry",
  "version": "1",
  "description": "A single entry in the Gnoseogenic Lexicon. Maps word → tier → engine component → failure mode → NS∞ architectural mapping.",
  "type": "object",
  "required": ["entry_id","word","tier","pie_root","semitic","cognitive_act","engine_component","failure_mode","priority","ns_mapping","timestamp"],
  "additionalProperties": false,
  "properties": {
    "entry_id":        {"type": "string", "pattern": "^LEX-[A-Z0-9]{8}$"},
    "word":            {"type": "string"},
    "tier":            {"type": "integer", "minimum": 1, "maximum": 5},
    "pie_root":        {"type": "string"},
    "semitic":         {"type": "string"},
    "cognitive_act":   {"type": "string"},
    "engine_component":{"type": "string", "enum": ["gradient_source","intake","conversion","output","feedback","waste","meta_constraint"]},
    "failure_mode":    {"type": "string"},
    "priority":        {"type": "string", "pattern": "^P[1-5]$"},
    "ns_mapping":      {"type": "string"},
    "timestamp":       {"type": "string", "format": "date-time"}
  }
}
