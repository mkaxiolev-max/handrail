{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axiolev/abi/CommitEvent.v1",
  "title": "CommitEvent",
  "version": "1",
  "description": "Universal capability promotion gate. Founder authority at commit time.",
  "type": "object",
  "required": ["commit_id","capability_id","action","founder_approved","timestamp"],
  "additionalProperties": false,
  "properties": {
    "commit_id":       {"type":"string","pattern":"^CMT-[A-Z0-9]{8}$"},
    "capability_id":   {"type":"string"},
    "action":          {"type":"string","enum":["promote","reject","quarantine","downgrade"]},
    "from_state":      {"type":"string","enum":["desired","provisional","approved","committed","canonical"]},
    "to_state":        {"type":"string","enum":["desired","provisional","approved","committed","canonical"]},
    "founder_approved":{"type":"boolean"},
    "return_block_id": {"type":"string"},
    "git_hash":        {"type":"string"},
    "timestamp":       {"type":"string","format":"date-time"}
  }
}
