{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axiolev/abi/StateDelta.v1",
  "title": "StateDelta",
  "version": "1",
  "description": "Typed constitutional state change. Every consequential system action emits one or more StateDelta entries into the regulation ledger.",
  "type": "object",
  "required": ["state_delta_id","transition_id","delta_domain","target","before","after","proof_ref","timestamp"],
  "additionalProperties": false,
  "properties": {
    "state_delta_id": {"type": "string", "pattern": "^SDL-[A-Z0-9]{8}$"},
    "transition_id":  {"type": "string"},
    "delta_domain":   {"type": "string", "enum": ["epistemic","operational","constitutional","commercial"]},
    "target":         {"type": "string"},
    "before":         {"type": "object"},
    "after":          {"type": "object"},
    "proof_ref":      {"type": "string"},
    "timestamp":      {"type": "string", "format": "date-time"}
  }
}
