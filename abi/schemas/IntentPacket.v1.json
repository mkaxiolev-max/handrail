{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axiolev/abi/IntentPacket.v1",
  "title": "IntentPacket",
  "version": "1",
  "description": "Universal ingress contract. Every action in NS∞ begins here.",
  "type": "object",
  "required": ["intent_id","source_surface","raw_input","timestamp","session_id"],
  "additionalProperties": false,
  "properties": {
    "intent_id":       {"type":"string","pattern":"^INT-[A-Z0-9]{8}$"},
    "source_surface":  {"type":"string","enum":["voice","text","nsctl","email","autopoietic","boot"]},
    "raw_input":       {"type":"string","minLength":1},
    "normalized_text": {"type":"string"},
    "confidence":      {"type":"number","minimum":0,"maximum":1},
    "timestamp":       {"type":"string","format":"date-time"},
    "session_id":      {"type":"string"},
    "founder_present": {"type":"boolean","default":false},
    "dignity_budget":  {"type":"number","minimum":0,"maximum":1,"default":1.0}
  }
}
