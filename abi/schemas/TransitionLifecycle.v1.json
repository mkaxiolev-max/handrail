{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axiolev/abi/TransitionLifecycle.v1",
  "title": "TransitionLifecycle",
  "version": "1",
  "description": "Full lifecycle record for one constitutional action. Every non-trivial action that changes system state must produce one TransitionLifecycle.",
  "type": "object",
  "required": ["transition_id","source_surface","objective","sovereign","timestamp"],
  "additionalProperties": false,
  "properties": {
    "transition_id":  {"type": "string", "pattern": "^TRN-[A-Z0-9]{8}$"},
    "source_surface": {"type": "string", "enum": ["voice","text","console","api","system","boot","trading"]},
    "objective":      {"type": "string"},
    "intent_ref":     {"type": "string"},
    "decision_ref":   {"type": "string"},
    "cps_ref":        {"type": "string"},
    "return_ref":     {"type": "string"},
    "proof_ref":      {"type": "string"},
    "state_deltas":   {"type": "array", "items": {"type": "string"}},
    "sovereign":      {"type": "boolean"},
    "timestamp":      {"type": "string", "format": "date-time"},
    "metadata":       {"type": "object"}
  }
}
